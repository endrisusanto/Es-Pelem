{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Es Pelem",
  "version": "0.1.10",
  "identifier": "com.endri-pro.es-pelem",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Es Pelem",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "dangerousRemoteDomainIpcAccess": [
        {
          "domain": "mdvh.sec.samsung.net",
          "windows": ["sso-login"],
          "enableTauriAPI": true
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
